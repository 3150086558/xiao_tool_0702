#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Start Up Batch script
#
# This is a standard Maven Wrapper shell script.
# ----------------------------------------------------------------------------

# Based on: https://github.com/apache/maven-wrapper

set -e

# Determine the project base directory
PRG="$0"

# Need this for relative symlinks
while [ -h "$PRG" ] ; do
    ls=`ls -ld "$PRG"`
    link=`expr "$ls" : '.*-> \(.*\)$'`
    if expr "$link" : '/.*' > /dev/null; then
        PRG="$link"
    else
        PRG=`dirname "$PRG"`"/$link"
    fi
done

SAVED="`pwd`"
cd "`dirname \"$PRG\"`/" >/dev/null
APP_HOME="`pwd -P`"
cd "$SAVED" >/dev/null

# Resolve links: $0 may be a link
MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$APP_HOME}"
export MAVEN_PROJECTBASEDIR

if [ -z "$MAVEN_CONFIG" ]; then
    MAVEN_CONFIG=""
fi

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD="maximum"

warn () {
    echo "$*"
} >&2

die () {
    echo
    echo "$*"
    echo
    exit 1
} >&2

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
darwin=false
nonstop=false
case "`uname`" in
  CYGWIN* )
    cygwin=true
    ;;
  Darwin* )
    darwin=true
    ;;
  MSYS* | MINGW* )
    msys=true
    ;;
  NONSTOP* )
    nonstop=true
    ;;
esac

CLASSPATH=$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD="`which java`"
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
fi

# For Cygwin, switch paths to Windows format before running java
if $cygwin ; then
    [ -n "$MAVEN_PROJECTBASEDIR" ] &&
        MAVEN_PROJECTBASEDIR=`cygpath --path --mixed "$MAVEN_PROJECTBASEDIR"`
    [ -n "$CLASSPATH" ] &&
        CLASSPATH=`cygpath --path --mixed "$CLASSPATH"`
fi

# special JMusicBrainz workaround...
if [ "$1" = "--debug" ] ; then
    MAVEN_OPTS="$MAVEN_OPTS -Xdebug -Xnoagent -Djava.compiler=NONE -Xrunjdwp:transport=dt_socket,server=y,suspend=y,address=8000"
    shift
fi

exec "$JAVACMD" \
    $MAVEN_OPTS \
    $MAVEN_DEBUG_OPTS \
    -classpath "$CLASSPATH" \
    -Dmaven.multiModuleProjectDirectory="${MAVEN_PROJECTBASEDIR}" \
    ${WRAPPER_LAUNCHER} $MAVEN_CONFIG "$@"
